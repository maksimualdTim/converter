		<servlet-name>ExchangeRatesServlet</servlet-name>
		<url-pattern>/ExchangeRatesServlet</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>ExchangeRateServlet</servlet-name>
		<url-pattern>/ExchangeRateServlet</url-pattern>
	</servlet-mapping>
